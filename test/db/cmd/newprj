axd 0x4010 0x1010
prj save .tmp/newprj-files.prj > /dev/null
f-*
ax-*
o--
o .tmp/newprj-a.bin 0x8000
o .tmp/newprj-b.bin 0xc000
prj load .tmp/newprj-files.prj > /dev/null
fd 0x8010
fd 0xc010
axq
rm .tmp/newprj-files.prj
rm .tmp/newprj-a.bin
rm .tmp/newprj-b.bin
EOF
EXPECT=<<EOF
first
second
0x00008010 -> 0x0000c010  DATA:r--
EOF
