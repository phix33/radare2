NAME=newprj flagspace round-trip
FILE=malloc://0x1000
CMDS=<<EOF
mkdir .tmp
rm -f .tmp/newprj-spc.prj
fs+alpha
f sym.one=0x100
fs+beta
f sym.two=0x200
prj save .tmp/newprj-spc.prj > /dev/null
f-*
fs-*
prj load .tmp/newprj-spc.prj > /dev/null
fs alpha
f~sym.one
fs beta
f~sym.two
rm .tmp/newprj-spc.prj
EOF
EXPECT=<<EOF
0x00000100 1 sym.one
0x00000200 1 sym.two
EOF
RUN

